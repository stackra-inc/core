{
  "name": "@stackra/realtime",
  "version": "0.1.0",
  "description": "Multi-driver realtime WebSocket manager — transport-agnostic, driver-registered. Client-side.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "realtime",
    "websocket",
    "socketio",
    "pusher",
    "react",
    "client-side"
  ],
  "homepage": "https://github.com/stackra-inc/core/tree/main/realtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/core.git",
    "directory": "realtime"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/core/issues"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      },
      "./react": {
        "types": "./dist/react.d.ts",
        "import": "./dist/react.mjs",
        "require": "./dist/react.js"
      },
      "./testing": {
        "types": "./dist/testing.d.ts",
        "import": "./dist/testing.mjs",
        "require": "./dist/testing.js"
      }
    }
  },
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "main": "./src/core/index.ts",
  "module": "./src/core/index.ts",
  "types": "./src/core/index.ts",
  "exports": {
    ".": {
      "types": "./src/core/index.ts",
      "import": "./src/core/index.ts",
      "require": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts",
      "require": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./src/testing/index.ts",
      "require": "./src/testing/index.ts",
      "default": "./src/testing/index.ts"
    }
  },
  "files": [
    "config",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "peerDependencies": {
    "@stackra/container": "workspace:^",
    "@stackra/contracts": "workspace:^",
    "@stackra/logger": "workspace:^",
    "@stackra/support": "workspace:^",
    "react": "*",
    "reflect-metadata": "*"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stackra/container": "workspace:*",
    "@stackra/contracts": "workspace:*",
    "@stackra/logger": "workspace:*",
    "@stackra/support": "workspace:*",
    "@stackra/testing": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:types",
    "react": "catalog:react",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
