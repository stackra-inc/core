{
  "name": "@stackra/testing",
  "version": "1.0.0",
  "description": "Shared Vitest preset, setup lifecycle, and assertable primitives for the Stackra monorepo — SWC-based transform with full decorator metadata support.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "vitest",
    "vitest-preset",
    "testing",
    "swc",
    "decorators",
    "assertable"
  ],
  "homepage": "https://github.com/stackra-inc/core/tree/main/testing#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/core.git",
    "directory": "testing"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/core/issues"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      },
      "./matchers": {
        "types": "./dist/matchers.d.ts",
        "import": "./dist/matchers.mjs",
        "require": "./dist/matchers.js"
      },
      "./preset": {
        "types": "./dist/preset.d.ts",
        "import": "./dist/preset.mjs",
        "require": "./dist/preset.js"
      },
      "./setup": {
        "types": "./dist/setup.d.ts",
        "import": "./dist/setup.mjs",
        "require": "./dist/setup.js"
      }
    }
  },
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": [
    "./src/preset/setup.ts",
    "./dist/setup.js",
    "./dist/setup.mjs"
  ],
  "main": "./src/core/index.ts",
  "module": "./src/core/index.ts",
  "types": "./src/core/index.ts",
  "exports": {
    ".": {
      "types": "./src/core/index.ts",
      "import": "./src/core/index.ts",
      "require": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    },
    "./matchers": {
      "types": "./src/matchers/index.ts",
      "import": "./src/matchers/index.ts",
      "require": "./src/matchers/index.ts",
      "default": "./src/matchers/index.ts"
    },
    "./preset": {
      "types": "./src/preset/index.ts",
      "import": "./src/preset/index.ts",
      "require": "./src/preset/index.ts",
      "default": "./src/preset/index.ts"
    },
    "./setup": {
      "types": "./src/preset/setup.ts",
      "import": "./src/preset/setup.ts",
      "require": "./src/preset/setup.ts",
      "default": "./src/preset/setup.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "peerDependencies": {
    "vitest": "*"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": false
    }
  },
  "dependencies": {
    "@swc/core": "catalog:",
    "unplugin-swc": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
