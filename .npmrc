# pnpm configuration
# Docs: https://pnpm.io/npmrc

# Automatically install peer dependencies declared by workspace packages.
auto-install-peers=true

# Optional peer deps in workspace packages (marked peerDependenciesMeta.optional)
# should not cause "unmet peer" install failures.
strict-peer-dependencies=false

# Keep the node_modules layout strict — no hoisting into consumer packages.
# Prevents packages from accidentally using deps they don't declare.
shamefully-hoist=false

# Prefer workspace protocol for intra-repo deps when linking.
prefer-workspace-packages=true
link-workspace-packages=true

# Save exact catalog names (not resolved versions) when adding deps.
save-catalog=default

# Registry (defaults to public npm — override per team if needed).
# registry=https://registry.npmjs.org/
