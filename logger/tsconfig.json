{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "rootDir": ".",
    "paths": { "@/*": ["./src/*"] },
    "outDir": "./dist",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "__tests__"]
}
