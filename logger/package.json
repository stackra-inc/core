{
  "name": "@stackra/logger",
  "version": "0.1.0",
  "description": "Unified cross-platform logger — core, React, and NestJS entry points with pluggable reporters, enrichers, and formatters.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": ["stackra", "logger", "cross-platform", "nestjs", "react"],
  "homepage": "https://github.com/stackra-inc/core/tree/main/logger#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/core.git",
    "directory": "logger"
  },
  "bugs": { "url": "https://github.com/stackra-inc/core/issues" },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      },
      "./react": {
        "types": "./dist/react.d.ts",
        "import": "./dist/react.mjs",
        "require": "./dist/react.js"
      },
      "./testing": {
        "types": "./dist/testing.d.ts",
        "import": "./dist/testing.mjs",
        "require": "./dist/testing.js"
      }
    }
  },
  "packageManager": "pnpm@10.0.0",
  "engines": { "node": ">=22.0.0" },
  "sideEffects": false,
  "main": "./src/core/index.ts",
  "module": "./src/core/index.ts",
  "types": "./src/core/index.ts",
  "exports": {
    ".": "./src/core/index.ts",
    "./react": "./src/react/index.ts",
    "./testing": "./src/testing/index.ts"
  },
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@vivtel/metadata": "catalog:",
    "consola": "^3.4.2"
  },
  "peerDependencies": {
    "@nestjs/common": "*",
    "@nestjs/core": "*",
    "@stackra/container": "workspace:^",
    "@stackra/contracts": "workspace:^",
    "@stackra/support": "workspace:^",
    "pino": ">=9.0.0",
    "react": "*",
    "reflect-metadata": "*",
    "rxjs": "*"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true },
    "pino": { "optional": true },
    "react": { "optional": true },
    "rxjs": { "optional": true }
  },
  "devDependencies": {
    "@nestjs/common": "catalog:nestjs",
    "@nestjs/core": "catalog:nestjs",
    "@stackra/container": "workspace:*",
    "@stackra/contracts": "workspace:*",
    "@stackra/support": "workspace:*",
    "@stackra/testing": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:types",
    "pino": ">=10.3.1",
    "react": "catalog:react",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "rxjs": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
